# DeepSeek Code Agent - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 重要：永远不要将 .env 提交到 Git！

# DeepSeek API Key（必需）
# 推荐使用系统密钥管理器存储，而非明文文件：
#   Windows: 使用凭据管理器或 PowerShell: [System.Security.Cryptography.ProtectedData]
#   macOS:  使用 Keychain
#   Linux:  使用 libsecret / GNOME Keyring
DEEPSEEK_API_KEY=your_api_key_here

# 可选：自定义模型
# DEEPSEEK_MODEL=deepseek-chat
# PLANNER_MODEL=deepseek-reasoner

# 可选：上下文预算
# CONTEXT_MAX_TOKENS=30000

# 可选：沙箱配置
# SANDBOX_PROVIDER=docker
# SANDBOX_NETWORK=false